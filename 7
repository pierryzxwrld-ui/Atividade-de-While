#7. Peça várias notas ao usuário (encerra quando digitar -1) e calcule a média das notas válidas.
soma = 0
while True:
    n = float(input("Digite uma nota (digite -1 para encerrar):"))
    if n == -1:
        print("Programa encerrado")
        break
    soma = soma + n 
print("A media das notas sao:",soma)
