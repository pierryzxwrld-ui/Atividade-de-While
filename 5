#5. Peça números ao usuário continuamente e informe se cada número é par ou ímpar. O programa só deve parar quando o usuário digitar 0.
while True:
    n = int(input("Digite numeros inteiros:"))
    if n % 2 == 0:
        print("O numero é par")
    else:
        print("O numero é impar")
    if n == 0:
        print("Programa finalizado")
        break
